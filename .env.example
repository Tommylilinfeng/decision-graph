# ── Memgraph ──────────────────────────────────────────────
# CKG_MEMGRAPH_HOST=localhost
# CKG_MEMGRAPH_PORT=7687
# CKG_MEMGRAPH_URI=bolt://localhost:7687   # overrides HOST+PORT if set

# ── AI ────────────────────────────────────────────────────
# Required only if using ai.provider: "anthropic-api" in ckg.config.json
# ANTHROPIC_API_KEY=sk-ant-...

# Required only if using ai.embedding in ckg.config.json
# VOYAGE_API_KEY=pa-...

# ── Debug ─────────────────────────────────────────────────
# CKG_DEBUG=1

# ── Dashboard ─────────────────────────────────────────────
# DASHBOARD_PORT=3001
