{
  "name": "context-chain",
  "version": "0.1.0",
  "description": "Context Chain — MCP server for design decisions. grep finds what code does; we record why it was written that way.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "context-chain": "./bin/context-chain.js"
  },
  "files": [
    "bin/",
    "dist/mcp/",
    "dist/db/client.js",
    "dist/db/client.d.ts"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "build": "tsc --noEmit",
    "build:mcp": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build:mcp",
    "db:schema": "node_modules/.bin/ts-node src/db/schema.ts",
    "db:reset": "node_modules/.bin/ts-node src/db/reset.ts",
    "ingest:cpg": "node_modules/.bin/ts-node src/ingestion/ingest-cpg.ts",
    "ingest:sessions": "node_modules/.bin/ts-node --transpile-only src/ingestion/ingest-sessions.ts",
    "ingest:sessions:v2": "node_modules/.bin/ts-node --transpile-only src/ingestion/ingest-sessions-v2.ts",
    "link:repos": "node_modules/.bin/ts-node --transpile-only src/ingestion/link-repos.ts",
    "link:services": "node_modules/.bin/ts-node --transpile-only src/ingestion/link-services.ts",
    "link:tables": "node_modules/.bin/ts-node --transpile-only src/ingestion/link-tables.ts",
    "parse:sql": "node_modules/.bin/ts-node --transpile-only src/ingestion/parse-sql.ts",
    "cold-start": "node_modules/.bin/ts-node --transpile-only src/ingestion/cold-start.ts",
    "cold-start:v2": "node_modules/.bin/ts-node --transpile-only src/ingestion/cold-start-v2.ts",
    "embed:decisions": "node_modules/.bin/ts-node --transpile-only src/ingestion/embed-decisions.ts",
    "analyze": "node_modules/.bin/ts-node --transpile-only src/runners/analyze.ts",
    "cleanup": "node_modules/.bin/ts-node --transpile-only src/runners/cleanup-sessions.ts",
    "refine": "node_modules/.bin/ts-node --transpile-only src/ingestion/refine.ts",
    "connect": "node_modules/.bin/ts-node --transpile-only src/runners/connect.ts",
    "quota": "node_modules/.bin/ts-node --transpile-only scripts/check-quota.ts",
    "mcp": "node_modules/.bin/ts-node --transpile-only src/mcp/server.ts",
    "dashboard": "node_modules/.bin/ts-node --transpile-only src/dashboard/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@modelcontextprotocol/sdk": "^1.8.0",
    "hono": "^4.0.0",
    "neo4j-driver": "^5.19.0",
    "pgsql-parser": "^17.9.14",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "typescript": "^5.4.0"
  }
}
